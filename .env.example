# Reelarr environment — copy to .env and fill in. .env is gitignored; never
# commit real values. Defaults below use the real container-name URLs on the
# shared traefik_default Docker network.

# ==== Image override (leave default) ====
REELARR_IMAGE=dgshue/reelarr:latest

# ==== AI backend (LiteLLM proxy + local services) ====
LITELLM_BASE_URL=http://reelarr-litellm:4000
# Master key for the LiteLLM proxy (pick any secret string, e.g. `openssl rand -hex 24`)
LITELLM_MASTER_KEY=
# Model aliases defined in deploy/litellm-config.yaml
TEXT_MODEL=reelarr-text
VISION_MODEL=reelarr-vision
STT_MODEL=reelarr-stt
# Optional: hit an OpenAI-compatible STT server directly instead of via LiteLLM
# (the already-deployed Speaches instance works: http://ollama-speaches:8000/v1
#  from inside the network, or http://192.168.1.10:1111/v1 from outside)
STT_BASE_URL=
STT_API_KEY=
# Tier 3 (video frames -> vision LLM) — evidence accumulation + TMDB
# verification; needs qwen2.5vl:7b pulled in Ollama
ENABLE_VISION=true
# Frames sent to the vision model per clip, and their downscale width.
# ~1000 vision tokens/frame at 512px — 3 frames per call fits Ollama's
# default 4096 context; larger widths will overflow it.
FRAME_COUNT=6
FRAME_WIDTH=512
# Multi-title (listicle) cap — most titles ever offered from one post; a
# "top 50" post gets truncated to this, and the truncation is said openly
MAX_MULTI_TITLES=10
# Used for "is the model actually pulled" checks
OLLAMA_URL=http://ollama-nvidia:11434

# ==== Optional commercial AI keys (referenced from litellm-config.yaml) ====
GROQ_API_KEY=
GEMINI_API_KEY=

# ==== Metadata ====
# REQUIRED — free tier: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ==== Fulfillment (spec §5.5): "direct" (Radarr/Sonarr) or "seerr" ====
FULFILLMENT_TARGET=direct

RADARR_URL=http://radarr:7878
# Radarr -> Settings -> General -> Security -> API Key
RADARR_API_KEY=
RADARR_ROOT_FOLDER=
RADARR_QUALITY_PROFILE_ID=

SONARR_URL=http://sonarr:8989
# Sonarr -> Settings -> General -> Security -> API Key
SONARR_API_KEY=
SONARR_ROOT_FOLDER=
SONARR_QUALITY_PROFILE_ID=

SEERR_URL=http://overseerr:5055
# Overseerr -> Settings -> General -> API Key
SEERR_API_KEY=

# ==== Sources (intake channels) ====
# Telegram (priority channel) — token from @BotFather
TELEGRAM_BOT_TOKEN=
# Comma-separated chat IDs allowed to use the bot (message @userinfobot to find yours)
TELEGRAM_ALLOWED_CHAT_IDS=

# Discord (structural stub — adapter TODO)
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_CHANNEL_IDS=

# Slack, Socket Mode (structural stub — adapter TODO)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_CHANNEL_IDS=

# WhatsApp via Evolution API (OPT-IN — unofficial engine, ban risk; see README)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=reelarr
WHATSAPP_ALLOWED_NUMBERS=
